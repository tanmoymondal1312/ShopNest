[Unit]
Description=ShopNest FastAPI Application
After=network.target

[Service]
Type=exec
User=www-data
Group=www-data
WorkingDirectory=/var/www/shopnest
ExecStart=/var/www/shopnest/venv/bin/uvicorn main:app \
    --host 127.0.0.1 \
    --port 9000 \
    --workers 2 \
    --no-access-log
Restart=always
RestartSec=3
EnvironmentFile=/var/www/shopnest/.env

[Install]
WantedBy=multi-user.target
